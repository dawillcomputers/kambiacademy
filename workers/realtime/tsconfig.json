{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM"],
		"types": ["@cloudflare/workers-types"],
		"skipLibCheck": true,
		"strict": true,
		"isolatedModules": true,
		"noEmit": true,
		"allowImportingTsExtensions": true
	},
	"include": ["src/**/*.ts", "../../lib/liveClassroomProtocol.ts"]
}