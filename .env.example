AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4.5
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# If you use Google GenAI, set API_KEY instead
API_KEY=your_google_api_key_here
NODE_ENV=production

# LiveKit Configuration (for video conferencing)
VITE_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# Socket.io Configuration (for real-time chat)
# Set this only if you have a separate Socket.io service.
VITE_SOCKET_URL=
