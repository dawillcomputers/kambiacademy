AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4.5
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# If you use Google GenAI, set API_KEY instead
API_KEY=your_google_api_key_here
NODE_ENV=production

# Realtime classroom runtime secrets belong in .dev.vars / Pages secrets:
# REALTIME_JOIN_SECRET=
# CLOUDFLARE_REALTIME_APP_ID=
# CLOUDFLARE_REALTIME_APP_SECRET=

# Socket.io Configuration (for real-time chat)
# Set this only if you have a separate Socket.io service.
VITE_SOCKET_URL=
