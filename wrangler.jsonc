{
	"name": "kambiacademy",
	"pages_build_output_dir": "./dist",
	"compatibility_date": "2026-04-08",
	// Configure runtime secrets with `wrangler pages secret put` or a local `.dev.vars` file.
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "kambiacademy-db",
			"database_id": "d89ff5f6-5197-4469-ba2a-8bbe4da62e48"
		}
	],
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "kambi-academi-storage"
		}
	],
}
